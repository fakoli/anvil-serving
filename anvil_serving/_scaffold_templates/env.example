# Copy to examples/fakoli-dark/.env on Fakoli Dark and fill locally.
# The real .env file is gitignored.

# Required by Gepard on first model download.
HF_TOKEN=

# Optional: leave unset/empty to use the compose-managed gepard-postgres store.
GEPARD_DATABASE_URL=

# Optional: set to 100.87.34.66 only when Mini must reach Gepard directly.
VOICE_TTS_CANDIDATE_PUBLISH=

# Set to this host's tailnet address (100.87.34.66) so Fakoli Mini's realtime
# proxy can reach the STT/TTS bridge ports (30110/30111); loopback-only default.
VOICE_AUDIO_PUBLISH=
