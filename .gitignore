__pycache__/
*.pyc
.venv/
*.egg-info/
dist/
build/
.env
.env.*
!.env.example
!examples/**/.env.example
# uv lockfile — an env-provisioning artifact (the package is stdlib-only by
# design; pyproject declares no uv config). Not part of the project.
uv.lock
# local catalog state / pulled cards (regenerated by `anvil-serving models sync`)
model-library/cards/
model-library/notes/
model-library/_seen.json
.anvil/
*.local.toml
# bootstrap output (regenerated by `python -m anvil_serving.router.profile_bootstrap --replay`)
/profile.json
# stale pre-pivot internal resume note — not shipped publicly (removed from the repo)
HANDOFF.md

# Live voice proof captures can contain bulky/raw local audio. The default
# capture directory is temp, but ignore explicit in-repo capture prefixes too.
docs/findings/captures/
*.input.wav
*.output.wav
*.events.jsonl
*.latency.json
*.session.json

# MkDocs build output
site/

# Unsloth/torch.compile scratch dir emitted when running local model experiments
unsloth_compiled_cache/
