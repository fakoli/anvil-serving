// OpenClaw provider config — illustrative FLEXIBILITY-mode snapshot (reviewed 2026-07-17).
//
// Prefer `anvil-serving harness sync openclaw --config <router.toml> --dry-run`; it renders the
// current preset allowlist, context windows, and plugin-owned keys from the selected router config.
// Apply only on the OpenClaw GATEWAY host after reviewing that generated preview.
//
// CURRENT CONTRACT:
//   - The router owns model-family reasoning/thinking controls. The old per-preset
//     `agents.defaults.models["anvil/planning"|"anvil/long-context"].params...enable_thinking`
//     overrides stay absent; changing the served model must not require hand-editing this file.
//   - This snapshot reflects `examples/fakoli-dark/anvil-router.flexibility.toml`. A different
//     router config can add or remove presets, so generated output is authoritative.
//   - contextWindow remains the largest routed tier window (contextWindow-clamp gotcha).
//   - baseUrl/apiKey: the gateway is REMOTE from the router (Mini -> fakoli-dark), so this is NOT the
//     loopback/no-auth case. Point at fakoli-dark's reachable address and pass the router token.
{
  models: {
    mode: "merge",
    providers: {
      anvil: {
        // REPLACE <fakoli-dark-host> with fakoli-dark's Tailscale address (the router publishes
        // 0.0.0.0:8000 with token auth — ADR-0004). NOT 127.0.0.1 from Mini.
        // SECURITY: this sends the bearer token below. Use an ENCRYPTED path (Tailscale/WireGuard, or
        // a TLS-terminating reverse proxy → https). On a plain untrusted LAN, `http://` exposes the
        // token to on-net observers who could replay it against the router — don't use bare http there.
        baseUrl: "http://<fakoli-dark-host>:8000/v1",
        apiKey: "${ANVIL_ROUTER_TOKEN}",     // the router's bearer token (required off-loopback)
        api: "openai-completions",
        models: [
          { id: "planning",     name: "Anvil · Planning",     reasoning: true, input: ["text"],         contextWindow: 131072, maxTokens: 32000 },
          { id: "quick-edit",   name: "Anvil · Quick Edit",   reasoning: true, input: ["text"],         contextWindow: 131072, maxTokens: 8192  },
          { id: "review",       name: "Anvil · Review",       reasoning: true, input: ["text","image"], contextWindow: 131072, maxTokens: 16000 },
          { id: "chat",         name: "Anvil · Chat",         reasoning: true, input: ["text"],         contextWindow: 131072, maxTokens: 8192  },
          { id: "long-context", name: "Anvil · Long Context", reasoning: true, input: ["text"],         contextWindow: 131072, maxTokens: 16000 }
        ]
      }
    }
  },
  agents: { defaults: {
    model: { primary: "anvil/chat" },
    // agents.defaults.models is OpenClaw's DROPDOWN ALLOWLIST — a preset appears only if listed
    // here. List EVERY preset with EMPTY params: keep the allowlist entry, but strip per-preset
    // thinking overrides (the router owns model-family controls on its tiers). Deleting these
    // entries removes the anvil presets from OpenClaw's picker entirely.
    models: {
      "anvil/planning": {}, "anvil/quick-edit": {}, "anvil/review": {},
      "anvil/chat": {}, "anvil/long-context": {}
    }
  } },
  // key MUST be the packaged plugin id (plugins/openclaw-anvil-intent-router/), or the hook's
  // allowConversationAccess gate is never applied and intent routing silently no-ops.
  plugins: { entries: { "openclaw-anvil-intent-router": {
    hooks: { allowConversationAccess: true }
  } } }
}
